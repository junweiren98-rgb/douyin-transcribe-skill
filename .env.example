# 必填：Groq API Key（免费注册 https://console.groq.com）
GROQ_API_KEY=gsk_your_key_here

# 可选：OpenAI API Key（如果想用 OpenAI Whisper 替代 Groq）
# OPENAI_API_KEY=sk-your-key-here
# STT_PROVIDER=openai

# 可选：自定义 Whisper 模型（默认 whisper-large-v3）
# WHISPER_MODEL=whisper-large-v3

# 可选：自定义输出目录
# OUTPUT_DIR=./douyin-transcripts

# 可选：自定义 ffmpeg/ffprobe 路径（如果不在系统 PATH 中）
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe
